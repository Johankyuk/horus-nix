#!/usr/bin/env bash
# horus-privacy — privacidad de red por módulos: DNS cifrado (DoT), firewall y MAC aleatoria.
# Estado persistente en ~/.config/horus/privacy.
# Uso: horus-privacy            → TUI interactiva
#      horus-privacy --aplicar  → re-aplica estado guardado (setup/reinstalación)
#      horus-privacy --estado   → estado real del sistema
set -uo pipefail

ESTADO="$HOME/.config/horus/privacy"
mkdir -p "${ESTADO%/*}"

DNS=off; DNS_PROV=quad9; FIREWALL=off; MAC=off
[[ -f $ESTADO ]] && . "$ESTADO"

guardar() {
  printf 'DNS=%s\nDNS_PROV=%s\nFIREWALL=%s\nMAC=%s\n' "$DNS" "$DNS_PROV" "$FIREWALL" "$MAC" > "$ESTADO"
}

M=$'\e[38;2;139;69;247m'; S=$'\e[38;2;196;79;230m'
G=$'\e[38;2;130;130;130m'; V=$'\e[38;2;120;220;120m'; R=$'\e[0m'

srv_dns() {
  case $DNS_PROV in
    mullvad) echo "194.242.2.2#dns.mullvad.net" ;;
    *)       echo "9.9.9.9#dns.quad9.net 149.112.112.112#dns.quad9.net" ;;
  esac
}

dns_on() {
  sudo mkdir -p /etc/systemd/resolved.conf.d
  sudo tee /etc/systemd/resolved.conf.d/horus-dot.conf >/dev/null <<EOF
[Resolve]
DNS=$(srv_dns)
DNSOverTLS=yes
FallbackDNS=
Domains=~.
EOF
  sudo systemctl enable --now systemd-resolved.service
  sudo ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
  sudo systemctl restart NetworkManager
}

dns_off() {
  sudo rm -f /etc/systemd/resolved.conf.d/horus-dot.conf
  sudo systemctl disable --now systemd-resolved.service 2>/dev/null
  sudo rm -f /etc/resolv.conf
  sudo systemctl restart NetworkManager   # NM regenera resolv.conf clásico (DNS del router)
}

fw_on() {
  command -v ufw >/dev/null || sudo pacman -S --needed --noconfirm ufw
  sudo ufw default deny incoming >/dev/null
  sudo ufw default allow outgoing >/dev/null
  sudo ufw --force enable >/dev/null
  sudo systemctl enable ufw.service >/dev/null 2>&1 || true
}

fw_off() {
  command -v ufw >/dev/null && sudo ufw --force disable >/dev/null || true
}

mac_on() {
  sudo tee /etc/NetworkManager/conf.d/horus-mac.conf >/dev/null <<'EOF'
[device]
wifi.scan-rand-mac-address=yes

[connection]
# stable = MAC falsa pero consistente por red (menos fricción con portales/DHCP).
# Cambiar a "random" si se quiere MAC nueva en cada conexión.
wifi.cloned-mac-address=stable
EOF
  sudo systemctl restart NetworkManager
}

mac_off() {
  sudo rm -f /etc/NetworkManager/conf.d/horus-mac.conf
  sudo systemctl restart NetworkManager
}

estado_real() {
  echo
  echo "${M}DNS:${R}"
  if [[ -f /etc/systemd/resolved.conf.d/horus-dot.conf ]]; then
    resolvectl status 2>/dev/null | grep -E 'DNSOverTLS|Current DNS|DNS Servers' | sed 's/^/  /'
  else
    echo "  sin DoT (resolv.conf gestionado por NetworkManager)"
  fi
  echo "${M}Firewall:${R}"
  if command -v ufw >/dev/null; then sudo ufw status | sed 's/^/  /'; else echo "  ufw no instalado"; fi
  echo "${M}MAC:${R}"
  [[ -f /etc/NetworkManager/conf.d/horus-mac.conf ]] && echo "  aleatorización activa (stable)" || echo "  MAC de hardware"
  echo
}

tui() {
  sudo -v || exit 1
  while true; do
    clear
    local b1 b2 b3
    [[ $DNS == on ]]      && b1="${V}● ACTIVO ${R}" || b1="${G}○ apagado${R}"
    [[ $FIREWALL == on ]] && b2="${V}● ACTIVO ${R}" || b2="${G}○ apagado${R}"
    [[ $MAC == on ]]      && b3="${V}● ACTIVO ${R}" || b3="${G}○ apagado${R}"
    printf "
 ${M}◆ horus-privacy${R}  ${G}privacidad de red${R}

"
    printf "   ${S}[1]${R}  DNS cifrado (DoT · %-7s   %b
" "$DNS_PROV)" "$b1"
    printf "   ${S}[2]${R}  Firewall (entrada cerrada)   %b
" "$b2"
    printf "   ${S}[3]${R}  MAC aleatoria WiFi           %b

" "$b3"
    printf "   ${G}Pulsa el número para activar/desactivar.${R}
"
    printf "   ${S}[v]${R} ver estado real del sistema   ${S}[q]${R} salir

"
    printf " ${G}⚠ Portal cautivo o red conflictiva → apaga 1 y 3 temporalmente.${R}

 > "
    read -rsn1 k; echo
    case $k in
      1)
        if [[ $DNS == on ]]; then dns_off && DNS=off
        else
          printf "  Proveedor: ${S}[1]${R} Quad9  ${S}[2]${R} Mullvad > "
          read -rsn1 p; echo
          [[ $p == 2 ]] && DNS_PROV=mullvad || DNS_PROV=quad9
          dns_on && DNS=on
        fi ;;
      2) if [[ $FIREWALL == on ]]; then fw_off && FIREWALL=off; else fw_on && FIREWALL=on; fi ;;
      3) if [[ $MAC == on ]]; then mac_off && MAC=off; else mac_on && MAC=on; fi ;;
      v|V) estado_real; read -rsn1 -p "  (tecla para volver) " ;;
      q|Q) exit 0 ;;
    esac
    guardar
  done
}

case "${1:-}" in
  --aplicar)
    [[ $DNS == on ]] && dns_on
    [[ $FIREWALL == on ]] && fw_on
    [[ $MAC == on ]] && mac_on
    echo "horus-privacy: estado re-aplicado (DNS=$DNS FIREWALL=$FIREWALL MAC=$MAC)"
    ;;
  --estado) estado_real ;;
  *) tui ;;
esac
