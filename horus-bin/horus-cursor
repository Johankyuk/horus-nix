#!/usr/bin/env bash
# horus-cursor — genera y aplica cursores Bibata recoloreados por tema.
#   horus-cursor --build NOMBRE '#rrggbb' [--apply]   genera (lento, ~10 min)
#   horus-cursor --apply NOMBRE                        aplica en caliente
#   horus-cursor --all                                 pre-genera los 9 temas
set -u
HORUS_DIR="${HORUS_DIR:-$(cat "$HOME/.config/horus/repo" 2>/dev/null || echo "$HOME/Horus-Core")}"
SRC="/run/current-system/sw/share/icons/Bibata-Modern-Classic"
[ -d "$SRC" ] || SRC="/usr/share/icons/Bibata-Modern-Classic"
GTK3="$HOME/.config/gtk-3.0/settings.ini"; GTK4="$HOME/.config/gtk-4.0/settings.ini"

gtk_key() {  # archivo clave valor — replica apply_gtk_key del setup
  local f=$1 k=$2 v=$3; mkdir -p "$(dirname "$f")"; touch "$f"
  grep -q '^\[Settings\]' "$f" || printf '[Settings]\n' >> "$f"
  if grep -q "^$k=" "$f"; then sed -i "s|^$k=.*|$k=$v|" "$f"
  else sed -i "/^\[Settings\]/a $k=$v" "$f"; fi
}

aplicar() {
  local name=$1
  [ -d "$HOME/.icons/$name/cursors" ] || { echo "[err] $name no está generado."; return 1; }
  # Niri (config.kdl puede ser symlink de stow: --follow-symlinks para no romperlo)
  sed -i --follow-symlinks "s|xcursor-theme \".*\"|xcursor-theme \"$name\"|" "$HOME/.config/niri/config.kdl"
  command -v niri >/dev/null && niri msg action load-config-file >/dev/null 2>&1
  # GTK (apps vivas via gsettings; inis para las nuevas), XDG default, env, Flatpak
  gtk_key "$GTK3" gtk-cursor-theme-name "$name"; gtk_key "$GTK4" gtk-cursor-theme-name "$name"
  gsettings set org.gnome.desktop.interface cursor-theme "$name" 2>/dev/null || true
  mkdir -p "$HOME/.icons/default"
  printf '[Icon Theme]\nName=Default\nInherits=%s\n' "$name" > "$HOME/.icons/default/index.theme"
  mkdir -p "$HOME/.config/environment.d"
  sed -i "s|^XCURSOR_THEME=.*|XCURSOR_THEME=$name|" "$HOME/.config/environment.d/cursor.conf" 2>/dev/null \
    || printf 'XCURSOR_THEME=%s\nXCURSOR_SIZE=24\n' "$name" > "$HOME/.config/environment.d/cursor.conf"
  command -v flatpak >/dev/null && flatpak override --user --env=XCURSOR_THEME="$name" 2>/dev/null
  echo "[+] Cursor aplicado: $name (apps nuevas lo toman al abrir; las X11 viejas al re-login)"
}

construir() {
  local name=$1 color=$2 DEST="$HOME/.icons/$1"
  [ -d "$SRC" ] || { echo "[err] Falta bibata-cursor-theme (pacman -S bibata-cursor-theme)."; exit 1; }
  if ! mkdir /tmp/horus-cursor.lock 2>/dev/null; then
    echo "[i] Otro build de cursor está en curso; este se salta."; exit 0
  fi
  trap 'rmdir /tmp/horus-cursor.lock 2>/dev/null' EXIT
  echo "[i] Generando '$name' con base $color (tarda ~10 min)..."
  rm -rf "$DEST"; mkdir -p "$DEST/cursors"
  sed "s/Bibata Modern Classic/${name//-/ }/g; s/Bibata-Modern-Classic/$name/g" "$SRC/index.theme" > "$DEST/index.theme"
  [ -f "$SRC/cursor.theme" ] && sed "s/Bibata-Modern-Classic/$name/g" "$SRC/cursor.theme" > "$DEST/cursor.theme"
  local W; W=$(mktemp -d)
  # Paralelo por cursor (cada archivo Bibata es independiente): un job por hilo.
  local NJ; NJ=$(nproc)
  for cf in "$SRC/cursors/"*; do
    local n; n=$(basename "$cf")
    if [ -L "$cf" ]; then ln -sf "$(readlink "$cf")" "$DEST/cursors/$n"; continue; fi
    while [ "$(jobs -rp | wc -l)" -ge "$NJ" ]; do wait -n; done
    (
      mkdir -p "$W/$n" && cd "$W/$n" || exit 0
      xcur2png "$cf" > /dev/null 2>&1
      for png in *.png; do
        [ -f "$png" ] && magick "$png" \( -clone 0 -fill "$color" -colorize 100 \) \
          \( -clone 0 \) -delete 0 -compose Screen -composite "$png"
      done
      conf=$(ls *.conf 2>/dev/null | head -1)
      [ -n "$conf" ] && xcursorgen "$conf" "$DEST/cursors/$n" || cp "$cf" "$DEST/cursors/$n"
    ) &
  done
  wait
  rm -rf "$W"
  echo "[+] Cursor '$name' generado."
}

case "${1:-}" in
  --build)
    construir "$2" "$3"
    [ "${4:-}" = "--apply" ] && { aplicar "$2"; command -v notify-send >/dev/null && notify-send "Horus" "Cursor '$2' listo y aplicado."; }
    ;;
  --apply) aplicar "$2" ;;
  --all)
    python3 - << 'PY' | while read -r tema color; do
import sys, os
sys.path.insert(0, "/run/current-system/sw/bin")  # motor instalado por horus-tools
import horus_themes as kt
for t in kt.lista_temas():
    print(t.lower().replace(" ", "_"), kt.rotar_hex("#7a2be8", t))
PY
      [ "$tema" = "morado" ] && continue  # el morado ya existe (Bibata-Modern-Purple)
      [ -d "$HOME/.icons/Bibata-Horus-$tema/cursors" ] && { echo "[=] $tema ya generado."; continue; }
      "$0" --build "Bibata-Horus-$tema" "$color"
    done
    echo "✓ Pre-generación completa."
    ;;
  *) grep '^#   horus-cursor' "$0" | sed 's/^#   //' ;;
esac
