#!/usr/bin/env bash
# horus-remove — desinstalador interactivo con limpieza completa.
# Dos secciones: paquetes pacman explicitos y aplicaciones flatpak.
# Protege la infraestructura critica (boot, red, FS, audio, login, firewall),
# el grupo CachyOS core y el stack Horus. Ofrece limpieza de datos residuales
# en $HOME (pacman) y --delete-data (flatpak). Reusa el criterio de _quitar_pkg
# del setup: si algo lo requiere, se deja.

set -u

PURPLE='\033[0;35m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'
BLUE='\033[0;34m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

log()  { echo -e "${PURPLE}[horus]${NC} $1"; }
nota() { echo -e "${YELLOW}[i]${NC} $1"; }
err()  { echo -e "${RED}[x]${NC} $1"; }
hecho(){ echo -e "${GREEN}[+]${NC} $1"; }

# == Proteccion: infraestructura critica (romperla rompe el sistema) ==
# Por categoria funcional. Quitar cualquiera deja el sistema sin arrancar,
# sin red, sin montar discos, sin audio, sin login o sin firewall.
readonly -a PROTEGIDOS_INFRA=(
    # Base y toolchain
    base base-devel sudo git python perl paru
    bash-completion which less diffutils logrotate texinfo
    xdg-utils xdg-user-dirs rsync plocate
    # man
    man-db man-pages
    # Boot / initramfs / firmware / Secure Boot
    mkinitcpio efibootmgr efitools sbctl systemd-boot-manager
    os-prober amd-ucode intel-ucode linux-firmware
    # Filesystems y cifrado (BitLocker/LUKS dependen de estos)
    btrfs-progs e2fsprogs dosfstools exfatprogs f2fs-tools jfsutils
    nilfs-utils xfsprogs mtools cryptsetup lvm2 mdadm dmraid device-mapper
    # Discos / SMART / SCSI
    smartmontools hdparm sg3_utils sysfsutils lsscsi usb_modeswitch usbutils
    # Red + firewall
    networkmanager wpa_supplicant iwd dnsmasq nss-mdns netctl
    inetutils openssh modemmanager networkmanager-openvpn
    bind nfs-utils ethtool xl2tpd ufw ufw-extras
    # Audio (pipewire stack + firmware)
    pipewire pipewire-alsa pipewire-pulse pipewire-audio wireplumber
    alsa-utils alsa-firmware alsa-plugins sof-firmware pavucontrol
    # Bluetooth
    bluez bluez-utils bluez-libs bluez-obex bluez-hid2hci
    # Energia / arranque grafico base
    plymouth power-profiles-daemon upower
    # Gestor de paquetes
    pacman-contrib rebuild-detector pkgfile reflector
)

# == Proteccion: stack Horus (el entorno; quitarlo es incoherente) ==
readonly -a PROTEGIDOS_HORUS=(
    # Compositor + shell + terminal + file manager + theming + login
    niri noctalia-shell quickshell foot pcmanfm-qt qt6ct
    papirus-icon-theme papirus-folders sddm polkit-gnome
    xdg-desktop-portal-gtk xdg-desktop-portal
    # Teclado (remapeo latam) + fetch personalizado
    keyd fastfetch cachyos-niri-noctalia
    # Cadena del cursor Horus (horus-cursor la usa)
    bibata-cursor-theme xcur2png xorg-xcursorgen matugen-bin
    # Herramientas de energia/GPU que el setup despliega
    asusctl supergfxctl nvtop switcheroo-control
    # Utilidades Wayland del entorno
    wl-clipboard swww grim slurp wlsunset wob imv
)

# -- Indice de protegidos: infra + Horus + grupo CachyOS (consulta) --
# El grupo 'cachyos' cubre keyring, mirrorlists, hooks, settings, plymouth,
# chwd, etc. sin nombrarlos uno por uno.
declare -A PROTEGIDO
for p in "${PROTEGIDOS_INFRA[@]}" "${PROTEGIDOS_HORUS[@]}"; do
    PROTEGIDO["$p"]=1
done
while read -r p; do
    [ -n "$p" ] && PROTEGIDO["$p"]=1
done < <(pacman -Qqg cachyos 2>/dev/null)

# -- Patrones de categoria: system-base que no se lista por nombre --
es_protegido_por_patron() {
    grep -qE '(^linux(-cachyos)?(-lts|-zen|-hardened)?(-headers|-nvidia-open|-nvidia)?$)|(^linux-firmware)|(nvidia)|(^lib32-nvidia)|(^mesa$)|(^lib32-mesa)|(vulkan)|(xf86-video)|(^libva)|(amdgpu)|(opencl)|(^man-)|(progs$)|(-utils$)|(^gst-)|(^pipewire)|(^lib32-)' <<<"$1"
}

# ====================================================================
# Seleccion generica: array de items + array asociativo de metadatos.
# Resultado en SELECCION_OUT. Devuelve 1 si sale sin elegir, 2 si error.
# ====================================================================
SELECCION_OUT=()
seleccionar() {
    local -n _items="$1"
    local -n _meta="$2"
    local prompt="$3"
    SELECCION_OUT=()

    local i=1 pkg
    for pkg in "${_items[@]}"; do
        printf "  ${PURPLE}%3d${NC}  ${BOLD}%-30s${NC} ${DIM}%s${NC}\n" \
            "$i" "$pkg" "${_meta[$pkg:desc]:-}"
        local rb="${_meta[$pkg:reqby]:-None}"
        if [ "$rb" != "None" ] && [ -n "$rb" ]; then
            printf "       ${YELLOW}└ lo requiere: %s${NC}\n" "$rb"
        fi
        i=$((i+1))
    done

    echo ""
    echo -e "${DIM}  Numeros: '1 3 5', rangos '1-4', o combinado. Enter vacio = saltar.${NC}"
    read -rp "$(echo -e "${PURPLE}  ${prompt} >${NC} ")" entrada
    [ -z "${entrada// }" ] && return 1

    local -A SEL_IDX
    local token
    for token in $entrada; do
        if [[ "$token" =~ ^([0-9]+)-([0-9]+)$ ]]; then
            local a="${BASH_REMATCH[1]}" b="${BASH_REMATCH[2]}" t n
            [ "$a" -gt "$b" ] && { t=$a; a=$b; b=$t; }
            for ((n=a; n<=b; n++)); do SEL_IDX["$n"]=1; done
        elif [[ "$token" =~ ^[0-9]+$ ]]; then
            SEL_IDX["$token"]=1
        else
            err "Entrada invalida: '$token'"; return 2
        fi
    done

    local idx
    for idx in $(printf '%s\n' "${!SEL_IDX[@]}" | sort -n); do
        if [ "$idx" -lt 1 ] || [ "$idx" -gt "${#_items[@]}" ]; then
            err "Numero fuera de rango: $idx (hay ${#_items[@]})"; return 2
        fi
        SELECCION_OUT+=("${_items[$((idx-1))]}")
    done
    return 0
}

# ====================================================================
# SECCION 1 - PAQUETES PACMAN
# ====================================================================
seccion_pacman() {
    log "Analizando paquetes pacman..."
    local -a EXPLICITOS CANDIDATOS
    mapfile -t EXPLICITOS < <(pacman -Qqe | sort)

    local pkg
    CANDIDATOS=()
    for pkg in "${EXPLICITOS[@]}"; do
        [ -n "${PROTEGIDO[$pkg]:-}" ] && continue
        es_protegido_por_patron "$pkg" && continue
        CANDIDATOS+=("$pkg")
    done

    if [ "${#CANDIDATOS[@]}" -eq 0 ]; then
        nota "No hay paquetes pacman desinstalables."
        return 0
    fi

    local -A META
    local _cur=""
    while IFS= read -r line; do
        case "$line" in
            "Name"*)        _cur=$(awk -F': ' '{print $2}' <<<"$line") ;;
            "Description"*)
                local d; d=$(awk -F': ' '{print $2}' <<<"$line")
                [ "${#d}" -gt 46 ] && d="${d:0:43}..."
                META["$_cur:desc"]="$d" ;;
            "Required By"*) META["$_cur:reqby"]=$(awk -F': ' '{print $2}' <<<"$line") ;;
        esac
    done < <(LC_ALL=C pacman -Qi "${CANDIDATOS[@]}" 2>/dev/null)

    echo ""
    echo -e "${PURPLE}${BOLD}  PAQUETES PACMAN${NC}  ${DIM}(${#CANDIDATOS[@]} de ${#EXPLICITOS[@]} explicitos)${NC}"
    echo ""

    seleccionar CANDIDATOS META "quitar pkg"
    local rc=$?
    [ "$rc" -eq 1 ] && { log "Pacman: nada seleccionado."; return 0; }
    [ "$rc" -eq 2 ] && return 1
    [ "${#SELECCION_OUT[@]}" -eq 0 ] && return 0

    local -a SEL=("${SELECCION_OUT[@]}")

    echo ""
    echo -e "${YELLOW}${BOLD}  Se quitaran ${#SEL[@]} paquete(s) con deps huerfanas (-Rns):${NC}"
    echo ""
    local riesgo=0
    for pkg in "${SEL[@]}"; do
        local rb="${META[$pkg:reqby]:-None}"
        if [ "$rb" != "None" ] && [ -n "$rb" ]; then
            printf "    ${RED}•${NC} %-30s ${YELLOW}(lo requiere: %s)${NC}\n" "$pkg" "$rb"
            riesgo=1
        else
            printf "    ${RED}•${NC} %s\n" "$pkg"
        fi
    done
    echo ""
    [ "$riesgo" -eq 1 ] && nota "Los amarillos tienen dependientes; -Rns podria arrastrarlos o dejarlos."

    read -rp "$(echo -e "${RED}  ¿Confirmar desinstalacion? [s/N]:${NC} ")" ok
    case "$ok" in [sS]|[sS][iI]) ;; *) log "Pacman: cancelado."; return 0 ;; esac

    echo ""
    if sudo pacman -Rns --noconfirm "${SEL[@]}" 2>/dev/null; then
        hecho "Removidos: ${SEL[*]}"
    else
        nota "El lote fallo (dependencias). Reintentando uno por uno..."
        local -a REMOVIDOS=()
        for pkg in "${SEL[@]}"; do
            local reqby
            reqby=$(LC_ALL=C pacman -Qi "$pkg" 2>/dev/null | awk -F': ' '/^Required By/{print $2; exit}')
            if [ -n "$reqby" ] && [ "$reqby" != "None" ]; then
                nota "$pkg se deja (lo requiere: $reqby)."
            elif sudo pacman -Rns --noconfirm "$pkg" &>/dev/null; then
                hecho "Removido: $pkg"; REMOVIDOS+=("$pkg")
            else
                nota "$pkg no se pudo quitar; se deja."
            fi
        done
        SEL=("${REMOVIDOS[@]}")
    fi

    [ "${#SEL[@]}" -eq 0 ] && return 0
    limpiar_home_residual "${SEL[@]}"
}

# -- Busca restos en HOME por nombre, confirma y borra --
limpiar_home_residual() {
    local -a paquetes=("$@")
    local -a dirs_base=("$HOME/.config" "$HOME/.cache" "$HOME/.local/share")
    local -a hallazgos=()

    local pkg base d
    for pkg in "${paquetes[@]}"; do
        local nombre="${pkg%-bin}"; nombre="${nombre%-git}"
        for base in "${dirs_base[@]}"; do
            for d in "$base/$nombre" "$base/${nombre,,}"; do
                [ -d "$d" ] && hallazgos+=("$d")
            done
        done
    done

    [ "${#hallazgos[@]}" -eq 0 ] && return 0
    mapfile -t hallazgos < <(printf '%s\n' "${hallazgos[@]}" | sort -u)

    echo ""
    nota "Datos residuales encontrados en \$HOME:"
    local h
    for h in "${hallazgos[@]}"; do
        printf "    ${BLUE}%s${NC}  ${DIM}(%s)${NC}\n" "$h" "$(du -sh "$h" 2>/dev/null | cut -f1)"
    done
    echo ""
    nota "Esto es adivinado por nombre; revisa antes de borrar."
    read -rp "$(echo -e "${RED}  ¿Borrar estos datos? [s/N]:${NC} ")" ok
    case "$ok" in
        [sS]|[sS][iI])
            for h in "${hallazgos[@]}"; do
                rm -rf "$h" && hecho "Borrado: $h"
            done ;;
        *) log "Datos residuales conservados." ;;
    esac
}

# ====================================================================
# SECCION 2 - FLATPAKS
# ====================================================================
seccion_flatpak() {
    command -v flatpak &>/dev/null || return 0
    log "Analizando flatpaks..."

    # Se filtran runtimes/BaseApps (no son apps de usuario; los limpia --unused).
    local -a IDS NAMES
    local id nombre
    while IFS=$'\t' read -r id nombre; do
        [ -z "$id" ] && continue
        case "$id" in
            *.BaseApp|*.Locale|*.Debug|org.freedesktop.Platform*|org.kde.Platform*|org.gnome.Platform*) continue ;;
        esac
        IDS+=("$id"); NAMES+=("$nombre")
    done < <(flatpak list --app --columns=application,name 2>/dev/null)

    [ "${#IDS[@]}" -eq 0 ] && { nota "Sin flatpaks de usuario instalados."; return 0; }

    local -A META
    local i
    for i in "${!IDS[@]}"; do
        local _id="${IDS[$i]}" _nombre="${NAMES[$i]:-}"
        local datadir="$HOME/.var/app/$_id" size="-"
        [ -d "$datadir" ] && size=$(du -sh "$datadir" 2>/dev/null | cut -f1)
        META["$_id:desc"]="$_nombre  [datos: $size]"
    done

    echo ""
    echo -e "${PURPLE}${BOLD}  FLATPAKS${NC}  ${DIM}(${#IDS[@]} apps)${NC}"
    echo ""

    seleccionar IDS META "quitar flatpak"
    local rc=$?
    [ "$rc" -eq 1 ] && { log "Flatpak: nada seleccionado."; return 0; }
    [ "$rc" -eq 2 ] && return 1
    [ "${#SELECCION_OUT[@]}" -eq 0 ] && return 0

    local -a SEL=("${SELECCION_OUT[@]}")

    echo ""
    echo -e "${YELLOW}${BOLD}  Se desinstalaran ${#SEL[@]} flatpak(s) CON sus datos (--delete-data):${NC}"
    echo ""
    for id in "${SEL[@]}"; do
        local datadir="$HOME/.var/app/$id" size="-"
        [ -d "$datadir" ] && size=$(du -sh "$datadir" 2>/dev/null | cut -f1)
        printf "    ${RED}•${NC} %-40s ${DIM}(datos: %s)${NC}\n" "$id" "$size"
    done
    echo ""
    read -rp "$(echo -e "${RED}  ¿Confirmar? [s/N]:${NC} ")" ok
    case "$ok" in [sS]|[sS][iI]) ;; *) log "Flatpak: cancelado."; return 0 ;; esac

    echo ""
    for id in "${SEL[@]}"; do
        if flatpak uninstall --assumeyes --delete-data "$id" &>/dev/null; then
            hecho "Desinstalado (con datos): $id"
        else
            err "No se pudo desinstalar: $id"
        fi
    done
    flatpak uninstall --unused --assumeyes &>/dev/null && \
        hecho "Runtimes flatpak huerfanos limpiados."
}

# ====================================================================
main() {
    echo ""
    echo -e "${PURPLE}${BOLD}  horus-remove${NC} ${DIM}— desinstalador con limpieza completa${NC}"

    seccion_pacman  || nota "Seccion pacman interrumpida."
    seccion_flatpak || nota "Seccion flatpak interrumpida."

    echo ""
    echo -e "${GREEN}✓ terminado${NC}"
}

main "$@"
