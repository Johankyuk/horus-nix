#!/bin/bash
# horus-language — Selector de idioma del sistema (wizard de 1ª corrida).
#   Cambia el locale (LANG) del sistema. Como Noctalia y SDDM rinden la
#   fecha con tokens de Qt (ddd/MMM), el reloj sigue al locale solo:
#   "lun 24 jun" en espanol, "Mon 24 Jun" en ingles. No se parchea ningun
#   string de formato; solo el locale. El formato de hora (12h AM/PM) es
#   aparte y no lo toca el idioma.
#
#   Uso:
#     horus-language            selector interactivo (con easter egg)
#     horus-language es | en    no interactivo
#     horus-language --dry      muestra lo que haria, sin tocar nada (ni root)
#     horus-language --actual   idioma/locale activos
set -uo pipefail

P='\033[0;35m'; G='\033[0;32m'; Y='\033[1;33m'; D='\033[2m'; NC='\033[0m'

# idioma -> (locale, etiqueta, ejemplo de reloj)
loc_de()   { case "$1" in es) echo "es_MX.UTF-8";; en) echo "en_US.UTF-8";; esac; }
nombre_de(){ case "$1" in es) echo "Español";;     en) echo "English";;     esac; }
reloj_de() { case "$1" in es) echo "lun 24 jun";;  en) echo "Mon 24 Jun";;  esac; }

DRY=0

_egg() {
    {
    echo ""
    echo -e "  ${Y}* suck it toby fox${NC}"
    echo -e "  ${Y}* this is how u translate 1300+ code lines${NC}"
    echo -e "  ${Y}* ez bimbimbambam${NC}"
    echo ""
    } >&2
    sleep 1
}

_selector() {
    while :; do
        {
        echo -e "${P}╭───────────────────────────╮${NC}"
        echo -e "${P}│${NC}   Idioma / Language        ${P}│${NC}"
        echo -e "${P}╰───────────────────────────╯${NC}"
        echo -e "    ${G}1${NC}) Español"
        echo -e "    ${G}2${NC}) English"
        echo -ne "  > "
        } >&2
        read -r opt
        case "${opt,,}" in
            1|es|espanol|español) echo es; return 0 ;;
            2|en|english)         echo en; return 0 ;;
            toby|3|deltarune|bimbimbambam) _egg ;;   # easter egg: sigue preguntando
            *) echo -e "  ${Y}Opcion no valida.${NC}" >&2 ;;
        esac
    done
}

_aplicar() {
    local lang="$1" locale; locale="$(loc_de "$lang")"
    local nom; nom="$(nombre_de "$lang")"; local rel; rel="$(reloj_de "$lang")"

    echo -e "${P}Idioma:${NC} $nom   ${D}($locale)${NC}"

    if [ "$DRY" -eq 1 ]; then
        echo -e "${D}-- modo --dry: no se toca nada --${NC}"
        echo "  1) Asegurar en /etc/locale.gen:  ${locale%% *} UTF-8  (descomentar)"
        echo "  2) sudo locale-gen"
        echo "  3) sudo tee /etc/locale.conf  <- LANG=$locale"
        echo -e "  Reloj resultante: ${G}$rel${NC}   (Noctalia y SDDM, tras re-login/reboot)"
        return 0
    fi

    # 1) asegurar el locale habilitado en /etc/locale.gen
    if grep -qE "^[#[:space:]]*${locale}[[:space:]]+UTF-8" /etc/locale.gen 2>/dev/null; then
        sudo sed -i -E "s|^[#[:space:]]*(${locale}[[:space:]]+UTF-8)|\1|" /etc/locale.gen
    else
        echo "${locale} UTF-8" | sudo tee -a /etc/locale.gen >/dev/null
    fi
    # 2) generar
    sudo locale-gen >/dev/null 2>&1 && echo -e "  ${G}[+]${NC} locale generado: $locale"
    # 3) fijar como locale del sistema
    if [ "$(. /etc/locale.conf 2>/dev/null; echo "${LANG:-}")" = "$locale" ]; then
        echo -e "  ${P}[=]${NC} /etc/locale.conf ya estaba en $locale"
    else
        printf 'LANG=%s\n' "$locale" | sudo tee /etc/locale.conf >/dev/null
        echo -e "  ${G}[+]${NC} /etc/locale.conf -> LANG=$locale"
    fi
    # estado para el resto del sistema (ej. wizard de tema, scripts)
    mkdir -p "$HOME/.config/horus"; echo "$lang" > "$HOME/.config/horus/idioma"

    echo -e "  Reloj: ${G}$rel${NC}  →  toma efecto al cerrar sesión / reiniciar."
}

main() {
    local lang=""
    for a in "$@"; do
        case "$a" in
            --dry)     DRY=1 ;;
            --actual)
                echo "idioma: $(cat "$HOME/.config/horus/idioma" 2>/dev/null || echo '(sin definir)')"
                echo "LANG:   $(. /etc/locale.conf 2>/dev/null; echo "${LANG:-?}")"
                return 0 ;;
            -h|--help) sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'; return 0 ;;
            es|en)     lang="$a" ;;
            *) echo -e "${Y}Argumento desconocido: $a${NC}"; exit 2 ;;
        esac
    done

    [ -z "$lang" ] && lang="$(_selector)"
    case "$lang" in es|en) ;; *) echo -e "${Y}Idioma desconocido (usa es|en)${NC}"; exit 2 ;; esac
    _aplicar "$lang"
}
main "$@"
