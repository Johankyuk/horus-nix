#!/usr/bin/env bash
# En frío el hidraw del ITE5570 (0B05:19B6) tarda en enumerar; sin esperar,
# horus-kbd-fx sale sin encontrarlo y el teclado queda apagado.
LOG=~/.local/state/horus/logs/kbd-start.log
mkdir -p "$(dirname "$LOG")"
for i in $(seq 1 30); do
    for d in /sys/class/hidraw/hidraw*; do
        if grep -q "00000B05:000019B6" "$d/device/uevent" 2>/dev/null; then
            echo "$(date '+%F %T') device presente tras ${i}s ($d)" >> "$LOG"
            exec horus-kbd-fx "$@"
        fi
    done
    sleep 1
done
echo "$(date '+%F %T') TIMEOUT 30s: ITE5570 no apareció" >> "$LOG"
exec horus-kbd-fx "$@"
