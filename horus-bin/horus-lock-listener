#!/usr/bin/env bash
# horus-lock-listener — muestra el lockscreen de Noctalia cuando logind pide bloquear.
# Cubre el cierre de tapa (HandleLidSwitch=lock) y 'loginctl lock-session': logind
# emite la señal Lock y este puente llama al IPC de Noctalia. Corre dentro de la
# sesión, lanzado desde el autostart de Niri. La tecla power va por bind de Niri.
set -uo pipefail
command -v gdbus >/dev/null 2>&1 || { echo "Falta gdbus (glib2); no se puede escuchar el bloqueo."; exit 0; }

gdbus monitor --system --dest org.freedesktop.login1 2>/dev/null |
while read -r line; do
    case "$line" in
        *".Session.Lock ("*) qs -c noctalia-shell ipc call lockScreen lock >/dev/null 2>&1 ;;
    esac
done
