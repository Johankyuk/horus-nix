#!/usr/bin/env python3
# Control RGB del teclado ITE5570 via LampArray estandar (reports 0x41/0x45/0x46)
import sys, os, fcntl, glob

def HIDIOCSFEATURE(l): return 0xC0000000 | (l << 16) | 0x4806
def HIDIOCGFEATURE(l): return 0xC0000000 | (l << 16) | 0x4807

def find_kbd():
    for p in sorted(glob.glob("/sys/class/hidraw/hidraw*")):
        try:
            ue = open(os.path.join(p, "device/uevent")).read()
        except OSError:
            continue
        if "00000B05:000019B6" in ue:
            return "/dev/" + os.path.basename(p)
    return None

def hex_to_rgb(s):
    s = s.lstrip("#")
    return int(s[0:2], 16), int(s[2:4], 16), int(s[4:6], 16)

def main():
    if len(sys.argv) < 2:
        sys.exit("uso: horus-kbd-color RRGGBB [intensidad 0-255]")
    r, g, b = hex_to_rgb(sys.argv[1])
    inten = int(sys.argv[2]) if len(sys.argv) > 2 else 255

    dev = find_kbd()
    if not dev:
        sys.exit("No encontre el teclado ITE5570 en /sys/class/hidraw")
    print(f"Teclado: {dev}")

    fd = os.open(dev, os.O_RDWR)
    try:
        buf = bytearray(23); buf[0] = 0x41
        try:
            fcntl.ioctl(fd, HIDIOCGFEATURE(len(buf)), buf, True)
            count = buf[1] | (buf[2] << 8)
            print(f"LampCount: {count}")
        except OSError as e:
            count = 0
            print(f"No pude leer LampCount ({e}); uso rango amplio")
        end = (count - 1) if count > 0 else 0x00FF

        ctrl = bytes([0x46, 0x00])
        fcntl.ioctl(fd, HIDIOCSFEATURE(len(ctrl)), ctrl)
        print("Control tomado (autonomous off)")

        rng = bytes([0x45, 0x01]) + (0).to_bytes(2, "little") + end.to_bytes(2, "little") + bytes([r, g, b, inten])
        fcntl.ioctl(fd, HIDIOCSFEATURE(len(rng)), rng)
        print(f"Color #{sys.argv[1].lstrip('#')} enviado (intensidad {inten}) -> {rng.hex()}")
    finally:
        os.close(fd)

if __name__ == "__main__":
    main()
