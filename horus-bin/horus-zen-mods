#!/usr/bin/env python3
# horus-zen-mods — importa/mergea mods de Zen desde un export a la config del navegador.
#   Escribe en <perfil>/zen-themes.json (formato oficial de Zen). Al reiniciar Zen
#   (con internet) descarga y aplica los estilos. No pisa mods ya instalados: mergea por id.
#   Uso: horus-zen-mods [ruta-del-export.json]
import os, sys, json, glob, configparser

ZEN = next((d for d in (os.path.expanduser("~/.zen"),
                        os.path.expanduser("~/.config/zen"))
            if os.path.isdir(d)), os.path.expanduser("~/.zen"))
here = os.path.dirname(os.path.abspath(__file__))
EXPORT = sys.argv[1] if len(sys.argv) > 1 else None
if not EXPORT:  # buscar el export junto al script o en el repo
    for c in (os.path.join(here, "zen-mods-export.json"),
              os.path.join(here, "..", "config", "zen", "zen-mods-export.json"),
              os.path.expanduser("~/Horus-Project/config/zen/zen-mods-export.json")):
        if os.path.isfile(c): EXPORT = c; break
if not EXPORT or not os.path.isfile(EXPORT):
    sys.exit("[x] No encuentro el export de Zen mods.")

if not os.path.isdir(ZEN):
    print("[i] Zen no instalado (~/.zen no existe); nada que importar."); sys.exit(0)

# ── localizar el perfil por defecto ──
prof = None
ini = os.path.join(ZEN, "profiles.ini")
if os.path.isfile(ini):
    cp = configparser.ConfigParser(); cp.read(ini)
    # [Install...] es la autoridad en Firefox moderno; Default=1 es legacy.
    for s in cp.sections():
        if s.startswith("Install") and cp.has_option(s, "Default"):
            prof = os.path.join(ZEN, cp.get(s, "Default")); break
    # fallback legacy: perfil marcado Default=1
    if not prof:
        for s in cp.sections():
            if cp.has_option(s, "Path") and cp.get(s, "Default", fallback="0") == "1":
                p = cp.get(s, "Path")
                prof = os.path.join(ZEN, p) if cp.get(s, "IsRelative", fallback="1") == "1" else p
                break
if not prof:  # fallback: la carpeta con prefs.js más reciente
    cands = glob.glob(os.path.join(ZEN, "*", "prefs.js"))
    if cands: prof = os.path.dirname(max(cands, key=os.path.getmtime))
if not prof or not os.path.isdir(prof):
    sys.exit("[x] No hallé el perfil de Zen. Abre Zen una vez y reintenta.")

dst = os.path.join(prof, "zen-themes.json")
nuevos = json.load(open(EXPORT, encoding="utf-8"))
actual = {}
if os.path.isfile(dst):
    try: actual = json.load(open(dst, encoding="utf-8"))
    except Exception: actual = {}
    import shutil, datetime
    shutil.copy2(dst, dst + ".bak-" + datetime.datetime.now().strftime("%Y%m%d-%H%M%S"))

añadidos = [m["name"] for i, m in nuevos.items() if i not in actual]
actual.update(nuevos)  # mergea por id (no duplica; respeta lo ya instalado)
json.dump(actual, open(dst, "w", encoding="utf-8"), indent=2, ensure_ascii=False)
print(f"[+] Zen mods -> {dst}")
print(f"    Nuevos: {', '.join(añadidos) if añadidos else '(ninguno, ya estaban)'}. Total: {len(actual)}.")
print("    Reinicia Zen (con internet) para que descargue y aplique los estilos.")
