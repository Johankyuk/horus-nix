def _pantallas():
    # Nombres de salida segun niri (eDP-1, HDMI-A-1, ...); [""] como fallback.
    try:
        r = subprocess.run(["niri", "msg", "--json", "outputs"], capture_output=True, text=True)
        outs = list(json.loads(r.stdout).keys())
        return outs or [""]
    except Exception:
        return [""]

# ── 7) Teclado RGB (ITE5570 LampArray): color = primary del tema ──
def patch_kbd(tema, ts):
    color = kt.rotar_hex(kt.MORADA["mPrimary"], tema).lstrip("#")
    kbd_state = os.path.join(CFG, "horus", "kbd-color")  # lo lee el autostart
    actual = open(kbd_state).read().strip() if os.path.isfile(kbd_state) else None
    if actual == color:
        skip(f"Teclado RGB: ya en #{color}."); return
    if not shutil.which("horus-kbd-color"):
        warn("horus-kbd-color no está en PATH; teclado sin recolorear."); return
    r = subprocess.run(["horus-kbd-color", color], capture_output=True, text=True)
    if r.returncode == 0:
        os.makedirs(os.path.dirname(kbd_state), exist_ok=True)
        open(kbd_state, "w").write(color + "\n")
        did(f"Teclado RGB -> #{color}"); _CAMBIOS[0] = True
    else:
        warn(f"Teclado RGB no aplicado: {r.stderr.strip() or 'fallo horus-kbd-color'}")

def _cerrar_terminal():
    # Cierra la foot/footclient ancestro de este proceso (si existe). Lo lanzado
    # con setsid (Noctalia, build de cursor) queda fuera del arbol y sobrevive.
    # HORUS_NO_CLOSE la exporta horus-start: si el tema se aplica DENTRO del
    # setup, cerrar la terminal mataria la instalacion entera a media corrida.
    if os.environ.get("HORUS_NO_CLOSE"):
        return
    try:
        pid = os.getppid()
        for _ in range(10):
            if pid <= 1:
                return
            comm = open(f"/proc/{pid}/comm").read().strip()
            if comm in ("foot", "footclient"):
                time.sleep(0.5)
                os.kill(pid, 15)
                return
            pid = int(open(f"/proc/{pid}/status").read().split("PPid:")[1].split()[0])
    except Exception:
        pass

def refrescar_pcmanfm():
    # PCManFM-Qt cachea los iconos en memoria. El overlay Horus-Folders conserva
    # su nombre y solo cambia el CONTENIDO de los SVG, asi que una ventana abierta
    # no recarga los colores nuevos y Qt no ofrece recarga de icon-theme sin
    # reinicio. Unica via fiable: reiniciar el gestor. Reabre en la ubicacion por
    # defecto (la pestana exacta no es recuperable desde fuera del proceso).
    exe = shutil.which("pcmanfm-qt")
    if not exe: return
    if not subprocess.run(["pgrep","-x","pcmanfm-qt"],
                          capture_output=True, text=True).stdout.split(): return
    subprocess.run(["pkill","-x","pcmanfm-qt"], check=False)
    time.sleep(0.4)
    subprocess.Popen(["setsid", exe],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    did("PCManFM-Qt reiniciado (iconos del tema al dia).")

def reload_noctalia_live(png=None):
    # Repinta UI + wallpaper SIN reiniciar Noctalia. Al no matar el proceso, el
    # idle-inhibitor (caffeine) y demas estado en memoria sobreviven. foot y niri
    # recargan aparte (SIGUSR1 / load-config-file).
    if shutil.which("niri"):
        subprocess.run(["niri", "msg", "action", "load-config-file"], check=False)
    subprocess.run(["pkill", "-USR1", "foot"], check=False)
    if not shutil.which("qs"):
        warn("qs no disponible; Noctalia sin repintar via IPC."); return
    def _call(*a):
        return subprocess.run(["qs", "-c", "noctalia-shell", "ipc", "call", *a],
                              capture_output=True, text=True)
    r = _call("colorScheme", "set", "Horus Project")
    if r.returncode == 0:
        did("Noctalia: colorscheme repintado en vivo.")
    else:
        warn(f"colorScheme.set fallo: {r.stderr.strip()[:80]}")
    if not png: return
    if not os.path.isfile(png):
        warn(f"PNG del tema no existe: {png}"); return
    scrs = _pantallas()
    for scr in scrs:
        _call("wallpaper", "set", png, scr)
    got = _call("wallpaper", "get", scrs[0]).stdout or ""
    if os.path.basename(png) in got or png in got:
        did(f"Wallpaper -> {os.path.basename(png)} (en vivo)")
    else:
        warn("Noctalia no confirmo el wallpaper; reaplica o usa el selector.")

def aplicar(tema):
    canon = _resolver_tema(tema)
    if canon is None:
        sys.exit(f"[err] Tema desconocido: {tema}\n       Disponibles: {', '.join(kt.lista_temas())}")
    tema = canon
    ts = datetime.datetime.now().strftime("%Y%m%d-%H%M%S")
    print(f"{C['p']}Aplicando tema: {tema}{C['n']}  (repo: {REPO})")
    # ── Targets activos del tema ──────────────────────────────
    # El tema recolorea Niri, el teclado RGB, la paleta de Noctalia
    # (colorscheme + regeneración) y foot. El wallpaper se gestiona aparte.
    patch_niri(tema, ts)
    patch_kbd(tema, ts)        # ← teclado RGB sigue el primary del tema
    gen_colorscheme(tema, ts)  # ← reescribe el scheme "Horus Project" (dark + light)
    gen_foot(tema, ts)         # ← foot.ini del tema (ANSI semánticos fijos)
    recolorear_terminales()    # ← pinta las foot abiertas con el tema entrante
    patch_fastfetch(tema, ts)  # ← logo/keys/title de fastfetch siguen el tema
    gen_mangohud(tema, ts)     # ← overlay MangoHud con la paleta del tema
    gen_heroic(tema, ts)       # ← tema CSS de Heroic (aplica al reiniciarlo)
    patch_sddm(tema, ts)       # ← login SDDM via horus-sddm-apply (sudoers NOPASSWD)
    gen_darkreader(tema, ts)   # ← JSON para importar en Dark Reader (manual)
    patch_cursor(tema)         # cursor Bibata del tema (build en 2o plano si falta)
    gen_folders(tema, ts)      # ← carpetas Papirus recoloreadas (overlay Horus-Folders)
    gen_qt6ct(tema, ts)        # ← paleta Qt (PCManFM-Qt y demas apps Qt)
    save_state(tema)
    # ── Wallpaper + repintado en vivo (SIN reiniciar Noctalia: idle-inhibitor
    #    / caffeine y demas estado en memoria sobreviven) ──
    png = wallpaper_del_tema(tema)
    if _CAMBIOS[0] or os.environ.get("HORUS_FIRST") == "1":
        _asegura_dark(ts)          # default oscuro (archivo; sin restart)
        reload_noctalia_live(png)  # colorScheme.set + wallpaper set por pantalla (IPC)
        did(f"Tema '{tema}' aplicado en vivo (Niri + Noctalia + foot + Qt + carpetas + teclado + wallpaper + cursor). Respaldo: {os.path.join(BK_ROOT, ts)}")
    else:
        skip(f"Todo ya estaba en '{tema}'. Sin cambios.")
    if _FOLDERS[0]:
        refrescar_pcmanfm()
    _cerrar_terminal()

def _elegir():
    """Selector interactivo: lista los temas numerados y aplica el elegido."""
    temas = kt.lista_temas()
    cur = open(STATE).read().strip() if os.path.isfile(STATE) else None
    def e(s=""): print(s, file=sys.stderr)
    while True:
        e(f"{C['p']}╭─ Tema de Horus ─╮{C['n']}")
        for i, t in enumerate(temas, 1):
            sw = _swatch(kt.construir(t)["mPrimary"])
            marca = f" {C['ok']}(actual){C['n']}" if t == cur else ""
            e(f"  {C['ok']}{i:>2}{C['n']}) {sw}  {t}{marca}")
        print("  > ", end="", file=sys.stderr, flush=True)
        try:
            r = input().strip()
        except (EOFError, KeyboardInterrupt):
            e("\nCancelado."); return
        if r.isdigit() and 1 <= int(r) <= len(temas):
            aplicar(temas[int(r) - 1]); return
        if _resolver_tema(r):
            aplicar(r); return
        e(f"  {C['warn']}Opcion no valida.{C['n']}")

def main():
    a = sys.argv[1:]
    if a and a[0] in ("-h", "--help"):
        print("uso: horus-theme [Tema] | --elegir | --lista | --actual\n"
              "  sin argumentos abre el selector interactivo"); return
    if not a or a[0] == "--elegir":
        _elegir(); return
    if a[0] == "--lista":
        cur = open(STATE).read().strip() if os.path.isfile(STATE) else "(ninguno)"
        for t in kt.lista_temas():
            print(f"  {'* ' if t == cur else '  '}{t}")
        return
    if a[0] == "--actual":
        print(open(STATE).read().strip() if os.path.isfile(STATE) else "(ninguno)")
        return
    aplicar(" ".join(a))

if __name__ == "__main__":
    main()
