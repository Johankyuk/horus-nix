    _escribe_si_cambia(dst, out, f"Niri layout.kdl -> {tema}", ts)

# ── 4) Wallpaper: genera SVG del tema y lo rasteriza a PNG ────
def gen_wallpaper(tema, ts):
    if not os.path.isfile(SVG_BASE):
        warn(f"No hay {SVG_BASE}; wallpaper omitido."); return None
    plantilla = open(SVG_BASE, encoding="utf-8").read()
    svg = plantilla
    for hexo, rol in kt.WALLPAPER.items():
        svg = re.sub(re.escape(hexo), kt.construir(tema)[rol], svg, flags=re.IGNORECASE)
    slug = tema.lower().replace(" ", "_")
    svg_out = os.path.join(WALL_DIR, f"horus_{slug}.svg")
    png_out = os.path.join(WALL_DIR, f"horus_{slug}.png")
    _escribe_si_cambia(svg_out, svg, f"Wallpaper SVG -> {tema}", ts)
    # rasterizar (magick ya esta en el sistema por el tema de cursor)
    if shutil.which("magick"):
        subprocess.run(["magick", "-background", "none", svg_out,
                        "-resize", "3840x2160", png_out], check=False)
        did(f"Wallpaper PNG 4K -> {png_out}")
    else:
        warn("magick no disponible; quedo solo el SVG.")
    return png_out

def save_state(tema):
    os.makedirs(os.path.dirname(STATE), exist_ok=True)
    open(STATE, "w").write(tema + "\n")

# ── 6) SDDM: MainColor/AccentColor (requiere root; best-effort) ─
def patch_sddm(tema, ts):
    src = os.path.join(REPO, "sugar-dark-horus", "theme.conf")   # fuente Morada
    dst = "/var/lib/horus-sddm/theme.conf"
    if not os.path.isfile(src):
        warn("theme.conf SDDM (repo) no hallado; SDDM sin recolorear."); return
    out = _sub_hex(open(src, encoding="utf-8").read(), lambda h: True, tema)  # ambos colores rotan
    # ── theme.conf (colores) ──
    if os.path.isfile(dst) and open(dst, encoding="utf-8").read() == out:
        skip(f"SDDM theme.conf ya en '{tema}'.")
    else:
        r = subprocess.run(["sudo", "-n", "horus-sddm-apply"],
                           input=out, text=True, capture_output=True)
        if r.returncode == 0:
            did(f"SDDM theme.conf -> {tema}"); _CAMBIOS[0] = True
        else:
            warn("SDDM omitido: falta horus-sddm-apply o su regla sudoers (seccion sddm del setup).")
            return
    # ── Background.png = wallpaper del tema (mismo PNG que el escritorio) ──
    png = wallpaper_del_tema(tema)
    if not png:
        warn("SDDM fondo omitido: no hay PNG del tema en el repo."); return
    fondo_dst = os.path.join(os.path.dirname(dst), "Background.png")
    datos = open(png, "rb").read()
    try:
        if os.path.isfile(fondo_dst) and open(fondo_dst, "rb").read() == datos:
            skip("SDDM fondo ya en el wallpaper del tema."); return
    except Exception:
        pass
    r = subprocess.run(["sudo", "-n", "horus-sddm-apply", "fondo"],
                       input=datos, capture_output=True)
    if r.returncode == 0:
        did(f"SDDM fondo -> {os.path.basename(png)}"); _CAMBIOS[0] = True
    else:
        warn("SDDM fondo no se pudo escribir (helper fallo).")

# ── MangoHud: overlay de juego sigue la paleta del tema ──
def gen_mangohud(tema, ts):
    src = os.path.join(REPO_CFG, "MangoHud", "MangoHud.conf")  # fuente Morada
    dst = os.path.join(CFG, "MangoHud", "MangoHud.conf")
    if not os.path.isfile(src):
        warn("MangoHud.conf (repo) no encontrado; se omite."); return
    out = _sub_hex(open(src, encoding="utf-8").read(),
                   lambda h: h not in ANSI_FIJOS, tema)
    _escribe_si_cambia(dst, out, f"MangoHud -> {tema}", ts)
    # MangoHud relee el .conf en caliente: juegos abiertos se repintan solos.

# ── Dark Reader: JSON del tema para importar en Zen (paso manual) ──
def gen_darkreader(tema, ts):
    src = os.path.join(REPO_CFG, "darkreader", "darkreader.morado.json")   # fuente Morada
    dst = os.path.join(HOME, ".config", "horus", "darkreader.json")
    if not os.path.isfile(src):
        warn("darkreader-horus.json (repo) no encontrado; se omite."); return
    LUZ = {"#dcdad7", "#181818"}   # paleta del modo claro: no rota
    out = _sub_hex(open(src, encoding="utf-8").read(),
                   lambda h: h.lower() not in LUZ, tema)
    if os.path.isfile(dst) and open(dst, encoding="utf-8").read() == out:
        skip(f"Dark Reader JSON ya en '{tema}'."); return
    os.makedirs(os.path.dirname(dst), exist_ok=True)
    _backup(dst, ts)
    open(dst, "w", encoding="utf-8").write(out)
    did(f"Dark Reader -> {tema} (importa ~/.config/horus/darkreader.json en la extension)")
    _CAMBIOS[0] = True

