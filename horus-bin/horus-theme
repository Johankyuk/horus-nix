WALL_DIR = os.path.join(REPO, "Wallpapers")

# Conjuntos de color con doble rol — se anclan por-archivo.
ANSI_FIJOS = {v.lstrip('#').lower() for v in kt.ANSI_FIJOS.values()}  # red/green/.../bright
NIRI_ROTAN = ["7a2be8", "482a92", "b340e0"]   # decorativos; urgent (f5567a) queda fijo

C = {"ok": "\033[92m", "warn": "\033[93m", "p": "\033[95m", "n": "\033[0m"}
def did(m):  print(f"{C['ok']}[+]{C['n']} {m}")
def skip(m): print(f"{C['p']}[=]{C['n']} {m}")
def warn(m): print(f"{C['warn']}[i]{C['n']} {m}")

_CAMBIOS = [False]
_FOLDERS = [False]   # marca si gen_folders regenero SVGs (refresco PCManFM)
def _backup(path, ts):
    if os.path.exists(path):
        rel = os.path.relpath(path, HOME)
        dst = os.path.join(BK_ROOT, ts, rel)
        os.makedirs(os.path.dirname(dst), exist_ok=True)
        shutil.copy2(path, dst)

def _escribe_si_cambia(path, contenido, etiqueta, ts):
    if os.path.isfile(path) and open(path, encoding="utf-8").read() == contenido:
        skip(f"{etiqueta}: ya estaba al dia."); return
    _backup(path, ts)
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        f.write(contenido)
    did(etiqueta); _CAMBIOS[0] = True

def _sub_hex(texto, rotar_pred, tema):
    """Reemplaza cada hex de 6 chars segun rotar_pred(hex_lower)->bool."""
    def r(m):
        h = m.group(0).lower()
        return kt.rotar_hex("#" + h, tema).lstrip("#") if rotar_pred(h) else m.group(0)
    return re.sub(r'(?<![0-9a-fA-F])[0-9a-fA-F]{6}(?![0-9a-fA-F])', r, texto)

# ── 1) Colorscheme de Noctalia: dark + light generados desde roles ──
def _bloque(q, on, ons):
    return {
        "mPrimary": q["mPrimary"], "mOnPrimary": on,
        "mSecondary": q["mSecondary"], "mOnSecondary": on,
        "mTertiary": q["mTertiary"], "mOnTertiary": on,
        "mError": q["mError"], "mOnError": on,
        "mSurface": q["mSurface"], "mOnSurface": ons,
        "mSurfaceVariant": q["mSurfaceVariant"], "mOnSurfaceVariant": q["mOnSurfaceVariant"],
        "mOutline": q["mOutline"], "mShadow": q["mShadow"],
        "mHover": q["mHover"], "mOnHover": ons,
        "terminal": {
            "foreground": q["termFg"], "background": q["termBg"],
            "selectionFg": q["termSelFg"], "selectionBg": q["termSelBg"],
            "cursorText": q["termBg"], "cursor": q["termCursor"],
            "normal": {"black": q["black"], "red": q["red"], "green": q["green"],
                       "yellow": q["yellow"], "blue": q["blue"], "magenta": q["magenta"],
                       "cyan": q["cyan"], "white": q["white"]},
            "bright": {"black": q["blackBright"], "red": q["redBright"], "green": q["greenBright"],
                       "yellow": q["yellowBright"], "blue": q["blueBright"], "magenta": q["magentaBright"],
                       "cyan": q["cyanBright"], "white": q["whiteBright"]},
        },
    }

def gen_colorscheme(tema, ts):
    p  = kt.construir(tema)          # modo oscuro
    pl = kt.construir_light(tema)    # modo claro (paleta propia del tema)
    dark  = _bloque(p,  p["mOnPrimary"],  p["mOnSurface"])
    light = _bloque(pl, pl["mOnPrimary"], pl["mOnSurface"])
    dst = os.path.join(CFG, "noctalia", "colorschemes", "Horus Project", "Horus Project.json")
    base = {"dark": dark, "light": light}
    _escribe_si_cambia(dst, json.dumps(base, indent=2, ensure_ascii=False) + "\n",
                       f"Colorscheme Noctalia (dark+light) -> {tema}", ts)

# ── 1b) qt6ct: paleta Qt (PCManFM-Qt y cualquier app Qt) ─────
#   Sustituye al GTK-CSS de la era Thunar: Qt tematiza por PALETA (21 roles
#   QPalette en un INI), no por CSS fragil. Se genera desde el motor y se
#   asegura qt6ct.conf (estilo Fusion + ruta absoluta al esquema; por eso
#   qt6ct.conf NO vive en config/ del repo: la ruta cambia por usuario).
#   Orden fijo de qt6ct (Qt >= 6.6): WindowText Button Light Midlight Dark
#   Mid Text BrightText ButtonText Base Window Shadow Highlight
#   HighlightedText Link LinkVisited AlternateBase ToolTipBase ToolTipText
#   PlaceholderText Accent. Apps Qt abiertas toman el cambio al reabrirse.
def _qt6ct_filas(p):
    activa = [p["mOnSurface"], p["mSurfaceVariant"], p["mOutline"], p["mHover"],
              p["mShadow"], p["mSurfaceVariant"], p["mOnSurface"], p["mTertiary"],
              p["mOnSurface"], p["mSurface"], p["mSurface"], p["mShadow"],
              p["mPrimary"], p["mOnPrimary"], p["mSecondary"], p["mTertiary"],
              p["mSurfaceVariant"], p["mHover"], p["mOnSurface"],
              p["mOnSurfaceVariant"], p["mPrimary"]]
    off = list(activa)
    for i in (0, 6, 7, 8, 14, 15, 19, 20):     # textos/links/accent apagados
        off[i] = p["mOutline"]
    off[12], off[13] = p["mHover"], p["mOnSurfaceVariant"]
    inact = list(activa)                        # ventana sin foco: seleccion
    inact[12], inact[13] = p["mOutline"], p["mOnSurface"]  # apagada (como Niri)
    return activa, off, inact

def gen_qt6ct(tema, ts):
    activa, off, inact = _qt6ct_filas(kt.construir(tema))
    argb = lambda fila: ", ".join("#ff" + c.lstrip("#") for c in fila)
    esquema = os.path.join(CFG, "qt6ct", "colors", "horus.conf")
    _escribe_si_cambia(esquema,
                       "[ColorScheme]\n"
                       f"active_colors={argb(activa)}\n"
                       f"disabled_colors={argb(off)}\n"
                       f"inactive_colors={argb(inact)}\n",
                       f"Paleta Qt (qt6ct) -> {tema}", ts)
    icono = "Horus-Folders" if os.path.isdir(FOLDERS_DIR) else "Papirus-Dark"
    _escribe_si_cambia(os.path.join(CFG, "qt6ct", "qt6ct.conf"),
                       "[Appearance]\n"
                       f"color_scheme_path={esquema}\n"
                       "custom_palette=true\n"
                       f"icon_theme={icono}\n"
                       "style=Fusion\n"
                       "standard_dialogs=default\n",
                       "qt6ct.conf (Fusion + esquema Horus)", ts)

# ── 1c) Carpetas: overlay Horus-Folders (Papirus recoloreado al tema) ──
#   Sustituye a papirus-folders (AUR): en vez de elegir entre familias
#   pre-horneadas de Papirus (los verdes no cuadraban), se toma la familia
#   violet como plantilla y se rotan sus hex al tono/croma del mPrimary del
#   tema con el MISMO motor OKLCH. Los neutros (blanco/gris, croma≈0) no se
#   mueven. El overlay hereda de Papirus-Dark: solo trae folder*.svg, todo
#   lo demas lo sigue dando Papirus. gtk-update-icon-cache al final.
PAPIRUS_VIOLET = "#7e57c2"   # color principal de la familia plantilla
FOLDERS_DIR = os.path.join(HOME, ".local", "share", "icons", "Horus-Folders")

def _papirus_dir():
    for d in ("/run/current-system/sw/share/icons/Papirus",
              "/usr/share/icons/Papirus",
              os.path.join(HOME, ".local", "share", "icons", "Papirus")):
        if os.path.isdir(d):
            return d
    return None

def _set_ini_key(path, seccion, clave, valor):
    """Fija clave=valor en un INI simple (settings.ini de GTK). Best-effort."""
    try:
        lineas = open(path, encoding="utf-8").read().splitlines() if os.path.isfile(path) else [f"[{seccion}]"]
        if not any(l.strip() == f"[{seccion}]" for l in lineas):
            lineas.insert(0, f"[{seccion}]")
        out, hecho = [], False
        for l in lineas:
            if l.split("=")[0].strip() == clave:
                l, hecho = f"{clave}={valor}", True
            out.append(l)
        if not hecho:
            out.insert(next(i for i, l in enumerate(out) if l.strip() == f"[{seccion}]") + 1,
                       f"{clave}={valor}")
        os.makedirs(os.path.dirname(path), exist_ok=True)
        open(path, "w", encoding="utf-8").write("\n".join(out) + "\n")
        return True
    except Exception:
        return False

# Nombres estandar que GIO/Qt piden PRIMERO; si faltan, el lookup cae al tema
# padre (Papirus violet) y el color miente. Se generan como copias del arte rotado.
ALIAS_FOLDERS = {
    "inode-directory": "folder",
    "gtk-directory":   "folder",
    "stock_folder":    "folder",
    "user-desktop":    "folder-desktop",
    "desktop":         "folder-desktop",
    "folder-publicshare": "folder-public",
    "folder-home":     "user-home",
}
def gen_folders(tema, ts):
    src_root = _papirus_dir()
    if not src_root:
        warn("Papirus no esta instalado; carpetas del tema se omiten."); return
    if tema == "Gris":
        rot = lambda h: kt._rot(h, 0, gray=True)
    else:
        Lp, Cp, Hp = kt._lch(kt.construir(tema)["mPrimary"])
        Lv, Cv, Hv = kt._lch(PAPIRUS_VIOLET)
        dh, fC = (Hp - Hv) % 360, (min(1.6, Cp / Cv) if Cv else 1.0)
        rot = lambda h: kt._rot(h, dh, fC=fC)
    rx = re.compile(r"#([0-9a-fA-F]{6})\b")
    sizes, escritos, total = [], 0, 0
    for size_dir in sorted(os.listdir(src_root)):
        places = os.path.join(src_root, size_dir, "places")
        svgs = sorted(glob.glob(os.path.join(places, "folder-violet*.svg"))
                      + glob.glob(os.path.join(places, "user-violet*.svg")))
        if not svgs:
            continue
        out_dir = os.path.join(FOLDERS_DIR, size_dir, "places")
        os.makedirs(out_dir, exist_ok=True)
        sizes.append(size_dir)
        for svg in svgs:
            base = os.path.basename(svg)
            if base.startswith("folder-violet"):
                nombre = "folder" + base[len("folder-violet"):]
            else:
                nombre = "user" + base[len("user-violet"):]
            txt = open(os.path.realpath(svg), encoding="utf-8").read()
            out = rx.sub(lambda m: rot("#" + m.group(1)), txt)
            dstf = os.path.join(out_dir, nombre); total += 1
            if not (os.path.isfile(dstf) and open(dstf, encoding="utf-8").read() == out):
                open(dstf, "w", encoding="utf-8").write(out); escritos += 1
        for alias, base in ALIAS_FOLDERS.items():
            srcf = os.path.join(out_dir, base + ".svg")
            dstf = os.path.join(out_dir, alias + ".svg")
            if not os.path.isfile(srcf):
                continue
            txt = open(srcf, encoding="utf-8").read(); total += 1
            if not (os.path.isfile(dstf) and open(dstf, encoding="utf-8").read() == txt):
                open(dstf, "w", encoding="utf-8").write(txt); escritos += 1
    if not sizes:
        warn("Papirus sin familia violet (places); carpetas se omiten."); return
    idx = ("[Icon Theme]\nName=Horus-Folders\n"
           "Comment=Carpetas Papirus recoloreadas al tema Horus\n"
           "Inherits=Papirus-Dark,Papirus,hicolor\n"
           f"Directories={','.join(s + '/places' for s in sizes)}\n\n"
           + "\n".join(f"[{s}/places]\nSize={s.split('x')[0]}\nContext=Places\nType=Fixed\n"
                       for s in sizes))
    _escribe_si_cambia(os.path.join(FOLDERS_DIR, "index.theme"), idx,
                       "index.theme (Horus-Folders)", ts)
    if escritos:
        _CAMBIOS[0] = True
        _FOLDERS[0] = True
        did(f"Carpetas -> {tema} ({escritos}/{total} SVG regenerados).")
    else:
        skip(f"Carpetas: ya estaban en '{tema}' ({total} SVG).")
    try:
        subprocess.run(["gtk-update-icon-cache", "-f", "-q", FOLDERS_DIR],
                       check=False, capture_output=True)
    except FileNotFoundError:
        pass
    # GTK tambien apunta al overlay (PCManFM-Qt lo toma via qt6ct en gen_qt6ct)
    for ini in (os.path.join(CFG, "gtk-3.0", "settings.ini"),
                os.path.join(CFG, "gtk-4.0", "settings.ini")):
        _set_ini_key(ini, "Settings", "gtk-icon-theme-name", "Horus-Folders")
    subprocess.run(["gsettings", "set", "org.gnome.desktop.interface",
                    "icon-theme", "Horus-Folders"], check=False, capture_output=True)

# ── 2) foot: parchea colores (ANSI semanticos quedan fijos) ──
def gen_foot(tema, ts):
    src = os.path.join(REPO_CFG, "foot", "foot.ini")      # fuente Morada
    dst = os.path.join(CFG, "foot", "foot.ini")
    if not os.path.isfile(src):
        warn("foot.ini (repo) no encontrado; se omite."); return
    txt = open(src, encoding="utf-8").read()
    out = _sub_hex(txt, lambda h: h not in ANSI_FIJOS, tema)
    _escribe_si_cambia(dst, out, f"foot.ini -> {tema}", ts)

def recolorear_terminales():
    # foot NO recarga colores en caliente; pero SI obedece secuencias OSC en vivo.
    # Se le manda la paleta recien escrita en foot.ini a cada pty del usuario:
    # las terminales abiertas (incluida esta) se pintan del tema al instante.
    ini = os.path.join(CFG, "foot", "foot.ini")
    if not os.path.isfile(ini): return
    sec, colores = False, {}
    for ln in open(ini, encoding="utf-8"):
        ln = ln.strip()
        if ln.startswith("["):
            sec = (ln == "[colors-dark]"); continue
        if sec and "=" in ln:
            k, v = ln.split("=", 1)
            colores[k.strip()] = v.strip()
    seq = ""
    if "foreground" in colores: seq += f"\033]10;#{colores['foreground']}\a"
    if "background" in colores: seq += f"\033]11;#{colores['background']}\a"
    for i in range(8):
        if f"regular{i}" in colores: seq += f"\033]4;{i};#{colores[f'regular{i}']}\a"
        if f"bright{i}"  in colores: seq += f"\033]4;{i+8};#{colores[f'bright{i}']}\a"
    if not seq: return
    import glob as _g
    for pts in _g.glob("/dev/pts/[0-9]*"):
        if os.access(pts, os.W_OK):
            try:
                with open(pts, "w") as h: h.write(seq)
            except Exception: pass
    did("Terminales vivas recoloreadas (OSC).")

# ── 3) Niri: parchea solo los decorativos (urgent queda rojo) ─
