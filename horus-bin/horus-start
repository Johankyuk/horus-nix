#!/bin/bash
# Lanzador de setup_master.sh. NO esta atado a una ruta fija: se autolocaliza.
# Orden de resolucion del repo:
#   1) variable de entorno HORUS_DIR, si esta definida
#   2) ~/.config/horus/repo (archivo con la ruta; lo escribe bootstrap/setup)
#   3) busqueda en rutas comunes donde suele vivir el clon
# Vive en ~/.local/bin (en PATH) y el setup lo despliega ahi, asi que viaja
# con el repo a cualquier maquina sin editar nada.
set -uo pipefail

_find_repo() {
    if [ -n "${HORUS_DIR:-}" ] && [ -f "$HORUS_DIR/setup_master.sh" ]; then
        echo "$HORUS_DIR"; return
    fi
    local conf="$HOME/.config/horus/repo"
    if [ -f "$conf" ] && [ -f "$(cat "$conf")/setup_master.sh" ]; then
        cat "$conf"; return
    fi
    local d
    for d in "$HOME/Horus-Core" "$HOME/Proyectos/horus" "$HOME/Documentos/horus" \
             "$HOME/Documentos/Configs" "$HOME/.local/share/horus"; do
        [ -f "$d/setup_master.sh" ] && { echo "$d"; return; }
    done
}

REPO="$(_find_repo)"
if [ -z "$REPO" ]; then
    echo "horus-start: no encuentro el repo de Horus." >&2
    echo "  Defini la ruta con:  echo /ruta/al/repo > ~/.config/horus/repo" >&2
    echo "  o exporta:           HORUS_DIR=/ruta/al/repo" >&2
    exit 1
fi
exec bash "$REPO/setup_master.sh" "$@"
