#!/usr/bin/env bash
# horus-estado — panel de estado del ecosistema Horus (tema, energía, GPU, privacidad).
set -uo pipefail

M=$'\e[38;2;139;69;247m'; S=$'\e[38;2;196;79;230m'
G=$'\e[38;2;130;130;130m'; V=$'\e[38;2;120;220;120m'; R=$'\e[0m'

fila() { printf "  ${S}%-12s${R} %s\n" "$1" "$2"; }

# --- Tema activo ---
TEMA="desconocido"
for f in "$HOME/.config/horus/theme" "$HOME/.config/horus/tema"; do
  [[ -f $f ]] && TEMA=$(<"$f") && break
done

# --- Perfil de energía (EC vía platform_profile) ---
PERFIL=$(cat /sys/firmware/acpi/platform_profile 2>/dev/null || echo "desconocido")
case $PERFIL in
  quiet) PERFIL="quiet (silencioso)" ;;
  balanced) PERFIL="balanced (equilibrado)" ;;
  performance) PERFIL="${V}performance (rendimiento)${R}" ;;
esac

# --- GPU / alimentación ---
AC=off
for a in /sys/class/power_supply/{AC*,ADP*}/online; do
  [[ -f $a && $(<"$a") == 1 ]] && AC=on && break
done
RTX=$(cat /sys/bus/pci/devices/0000:01:00.0/power/runtime_status 2>/dev/null || echo "?")
if [[ $AC == on ]]; then
  GPU="RTX 4050 (${RTX}) · corriente ${V}AC${R}"
else
  GPU="Radeon 780M · ${G}batería${R} (RTX: ${RTX})"
fi

# --- Privacidad ---
DNS=off; DNS_PROV=quad9; FIREWALL=off; MAC=off
[[ -f $HOME/.config/horus/privacy ]] && . "$HOME/.config/horus/privacy"
on_off() { [[ $1 == on ]] && echo "${V}● activo${R}${2:+ ($2)}" || echo "${G}○ apagado${R}"; }

# --- Sistema ---
KERNEL=$(uname -r)
UPT=$(uptime -p | sed 's/^up //')

printf "\n ${M}◆ Horus${R}  ${G}%s@%s${R}\n" "$USER" "$(hostname)"
printf " ${G}─────────────────────────────────────────${R}\n"
fila "Tema"      "$TEMA"
fila "Energía"   "$PERFIL"
fila "GPU"       "$GPU"
fila "DNS"       "$(on_off "$DNS" "DoT $DNS_PROV")"
fila "Firewall"  "$(on_off "$FIREWALL")"
fila "MAC WiFi"  "$(on_off "$MAC" "aleatoria")"
fila "Kernel"    "$KERNEL"
fila "Uptime"    "$UPT"
echo
