#!/usr/bin/env bash
# horus-fsr — wrapper gamescope para opciones de lanzamiento de Steam/Heroic.
#   Uso en Steam:  horus-fsr %command%
#   Render interno 720p -> upscale FSR a 1080p, fullscreen.
#   Variables opcionales: HFSR_W/HFSR_H (render), HFSR_R (cap de FPS).
exec gamescope \
    -w "${HFSR_W:-1280}" -h "${HFSR_H:-720}" \
    -W 1920 -H 1080 -F fsr -f \
    ${HFSR_R:+-r "$HFSR_R"} \
    -- "$@"
