#!/usr/bin/env python3
# horus-kbd-fx — efectos del teclado por software sobre LampArray (ITE5570).
#
# asusctl aura no soporta efectos en este equipo (FA607NUG), así que se animan
# por software con el mismo protocolo que horus-kbd-color (reports 0x46/0x45).
# Como el teclado es de 1 zona, solo hay efectos de teclado-completo.
#
#   horus-kbd-fx              corre el demonio (lee el modo y anima). Va en autostart.
#   horus-kbd-fx --next       rota al siguiente modo (lo ata F4). El demonio lo toma.
#   horus-kbd-fx <modo>       fija un modo concreto.
#   modos: estatico respiracion arcoiris pulso strobe
#
# Estado del modo:  ~/.config/horus/kbd-fx
# Color base (tema): ~/.config/horus/kbd-color  (lo escribe horus-theme)
# En 'estatico' el LED = color del tema; respiracion/pulso/strobe usan ese color;
# arcoiris cicla el tono. Reemplaza a horus-kbd-restore (también hace el estático).
import sys, os, fcntl, glob, time, math, colorsys

MODES = ["estatico", "respiracion", "arcoiris", "pulso", "strobe"]
CFG = os.path.expanduser("~/.config/horus")
FX_FILE = os.path.join(CFG, "kbd-fx")
COLOR_FILE = os.path.join(CFG, "kbd-color")

def HIDIOCSFEATURE(l): return 0xC0000000 | (l << 16) | 0x4806
def HIDIOCGFEATURE(l): return 0xC0000000 | (l << 16) | 0x4807

def find_kbd():
    for p in sorted(glob.glob("/sys/class/hidraw/hidraw*")):
        try:
            ue = open(os.path.join(p, "device/uevent")).read()
        except OSError:
            continue
        if "00000B05:000019B6" in ue:
            return "/dev/" + os.path.basename(p)
    return None

def leer_modo():
    try:
        m = open(FX_FILE).read().strip()
        return m if m in MODES else "estatico"
    except OSError:
        return "estatico"

def leer_color():
    try:
        c = open(COLOR_FILE).read().strip().lstrip("#")
        if len(c) == 6:
            return tuple(int(c[i:i+2], 16) for i in (0, 2, 4))
    except OSError:
        pass
    return (0x75, 0x23, 0xdb)  # morado oscuro por defecto

def fijar_modo(m):
    os.makedirs(CFG, exist_ok=True)
    with open(FX_FILE, "w") as f:
        f.write(m)

def siguiente():
    cur = leer_modo()
    nxt = MODES[(MODES.index(cur) + 1) % len(MODES)]
    fijar_modo(nxt)
    print(nxt)

# ── Conexión al teclado (con reintentos y reapertura ante fallo) ──
class Teclado:
    def __init__(self):
        self.fd = None
        self.end = 0x00FF

    def abrir(self, intentos=15):
        for _ in range(intentos):
            dev = find_kbd()
            if dev:
                try:
                    self.fd = os.open(dev, os.O_RDWR)
                    buf = bytearray(23); buf[0] = 0x41
                    try:
                        fcntl.ioctl(self.fd, HIDIOCGFEATURE(len(buf)), buf, True)
                        count = buf[1] | (buf[2] << 8)
                        self.end = (count - 1) if count > 0 else 0x00FF
                    except OSError:
                        self.end = 0x00FF
                    fcntl.ioctl(self.fd, HIDIOCSFEATURE(2), bytes([0x46, 0x00]))
                    return True
                except OSError:
                    self._cerrar()
            time.sleep(1)
        return False

    def _cerrar(self):
        if self.fd is not None:
            try: os.close(self.fd)
            except OSError: pass
            self.fd = None

    def envia(self, r, g, b, inten=255):
        r, g, b = (max(0, min(255, int(v))) for v in (r, g, b))
        rng = bytes([0x45, 0x01]) + (0).to_bytes(2, "little") + self.end.to_bytes(2, "little") + bytes([r, g, b, inten])
        try:
            fcntl.ioctl(self.fd, HIDIOCSFEATURE(len(rng)), rng)
            return True
        except OSError:
            # el teclado pudo re-enumerar (resume): reabrir
            self._cerrar()
            return self.abrir(intentos=10)

def escala(c, f):
    return tuple(int(v * f) for v in c)

def daemon():
    kb = Teclado()
    if not kb.abrir():
        sys.exit("No encontre el teclado ITE5570 (¿regla udev? ¿reinicio pendiente?)")
    t0 = time.time()
    while True:
        modo = leer_modo()
        base = leer_color()
        el = time.time() - t0
        if modo == "estatico":
            kb.envia(*base, 255); time.sleep(0.25)
        elif modo == "respiracion":
            f = 0.10 + 0.90 * (math.sin(el * 2.2) * 0.5 + 0.5)
            kb.envia(*escala(base, f), 255); time.sleep(0.04)
        elif modo == "arcoiris":
            hue = (el * 0.12) % 1.0
            rgb = tuple(int(x * 255) for x in colorsys.hsv_to_rgb(hue, 1, 1))
            kb.envia(*rgb, 255); time.sleep(0.04)
        elif modo == "pulso":
            f = 1.0 if (int(el * 1.6) % 2 == 0) else 0.12
            kb.envia(*escala(base, f), 255); time.sleep(0.05)
        elif modo == "strobe":
            f = 1.0 if (int(el * 9) % 2 == 0) else 0.0
            kb.envia(*escala(base, f), 255); time.sleep(0.04)
        else:
            time.sleep(0.25)

if __name__ == "__main__":
    if len(sys.argv) > 1 and sys.argv[1] == "--next":
        siguiente()
    elif len(sys.argv) > 1 and sys.argv[1] in MODES:
        fijar_modo(sys.argv[1]); print(sys.argv[1])
    else:
        daemon()
