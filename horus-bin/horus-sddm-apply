#!/usr/bin/env bash
# horus-sddm-apply — escribe archivos del tema SDDM desde stdin.
# Propósito único, destinos fijos:
#   horus-sddm-apply         → theme.conf
#   horus-sddm-apply fondo   → Background.png (fondo de login)
# Pensado para sudoers NOPASSWD.
set -euo pipefail
DIR="/var/lib/horus-sddm"
[[ $EUID -eq 0 ]] || { echo "horus-sddm-apply: requiere root" >&2; exit 1; }
mkdir -p "$DIR"
case "${1:-conf}" in
  conf)  cat > "$DIR/theme.conf" ;;
  fondo) cat > "$DIR/Background.png" ;;
  *) echo "horus-sddm-apply: modo invalido '$1' (conf|fondo)" >&2; exit 1 ;;
esac
