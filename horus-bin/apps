#!/bin/bash
# Alternativa al lanzador de Noctalia: muestra TODAS las apps instaladas (incluidas
# las ocultas del launcher minimo) con su id .desktop y su nombre, asi sabes que
# puedes correr sin el lanzador.
#   apps          -> lista todo (id  ->  nombre)
#   apps <id>     -> lanza esa app   (ej:  apps org.gimp.GIMP   apps vlc   apps pcmanfm-qt)
shopt -s nullglob

# Lanzar una app concreta por su id .desktop (gtk-launch ignora Hidden=true).
if [ -n "$1" ]; then
    if command -v gtk-launch >/dev/null && gtk-launch "$1" >/dev/null 2>&1; then exit 0; fi
    setsid -f "$1" >/dev/null 2>&1 && exit 0   # fallback: como binario directo
    echo "No pude lanzar '$1'. Revisa el id exacto con:  apps" >&2
    exit 1
fi

# Listar. Se recorre /usr/share primero (nombres reales) para que los overrides
# fantasma de ~/.local/share (los que ocultan apps) no pisen el nombre bueno.
declare -A SEEN
for d in /usr/share/applications "$HOME/.local/share/applications" \
         /var/lib/flatpak/exports/share/applications \
         "$HOME/.local/share/flatpak/exports/share/applications"; do
    for f in "$d"/*.desktop; do
        id=$(basename "$f" .desktop)
        [ -n "${SEEN[$id]:-}" ] && continue
        name=$(grep -m1 '^Name=' "$f" | cut -d= -f2-)
        SEEN[$id]="${name:-$id}"
    done
done
for id in $(printf '%s\n' "${!SEEN[@]}" | sort); do
    printf '  %-34s %s\n' "$id" "${SEEN[$id]}"
done
echo ""
echo "Lanzar:  apps <id>   |   o directo en la terminal el comando (vlc, gimp, pcmanfm-qt, meld...)"
