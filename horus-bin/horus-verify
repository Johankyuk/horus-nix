#!/usr/bin/env bash
# horus-verify — compara los dotfiles del repo vs tu ~/.config activa
# Se autolocaliza: usa HORUS_DIR o lee ~/.config/horus/repo.
HORUS_DIR="${HORUS_DIR:-$(cat "$HOME/.config/horus/repo" 2>/dev/null)}"
REPO="$HORUS_DIR/config"
[ -d "$REPO" ] || { echo "horus-verify: no encuentro el repo (define ~/.config/horus/repo o HORUS_DIR)" >&2; exit 1; }
P="\033[0;35m"; G="\033[0;32m"; Y="\033[1;33m"; N="\033[0m"
DIFFS=0
for item in niri foot noctalia/settings.json; do
    src="$REPO/$item"; dst="$HOME/.config/$item"
    [ -e "$dst" ] || { echo -e "${Y}[falta]${N} $dst no existe"; continue; }
    if diff -rq "$src" "$dst" &>/dev/null; then
        echo -e "${G}[=]${N} $item identico"
    else
        echo -e "${P}[!=]${N} $item difiere:"
        diff -rq "$src" "$dst" | sed "s/^/      /"
        DIFFS=1
    fi
done
[ $DIFFS -eq 0 ] && echo -e "\n${G}Todo sincronizado. Correr el flujo completo no pisa nada.${N}" \
                 || echo -e "\n${Y}Hay cambios locales sin capturar. Usa horus-sync antes de desplegar.${N}"
