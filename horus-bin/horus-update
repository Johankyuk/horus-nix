#!/bin/bash
# Actualiza todo en un solo comando: rankea mirrors (Arch + CachyOS), luego repos +
# AUR (paru) y por último los Flatpaks.
set -e
if command -v cachyos-rate-mirrors >/dev/null; then
    echo "→ Rankeando mirrors (Arch + CachyOS)..."
    sudo cachyos-rate-mirrors
fi
echo "→ Sistema (repos + AUR)..."
paru -Syu --noconfirm --skipreview --sudoloop
if command -v flatpak >/dev/null; then
    echo "→ Flatpaks..."
    flatpak update -y
fi
echo "✓ Todo actualizado."
