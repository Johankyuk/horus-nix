#!/usr/bin/env bash
# horus-gpu-watch — vigilante de perfil: en rendimiento+AC toda app NUEVA nace
# en la dGPU (env de sesión PRIME); fuera de eso, iGPU por default y horus-gpu
# decide por app. Las apps ya corriendo no migran (límite de híbrido).
set -u
VARS=(__NV_PRIME_RENDER_OFFLOAD __GLX_VENDOR_LIBRARY_NAME __VK_LAYER_NV_optimus DRI_PRIME)
_hay_dgpu(){ grep -q 0x10de /sys/bus/pci/devices/*/vendor 2>/dev/null; }
estado=""
_en_ac(){ for p in /sys/class/power_supply/*/online; do
    [ -r "$p" ] && [ "$(cat "$p" 2>/dev/null)" = "1" ] && return 0; done; return 1; }
while true; do
  prof=$(cat /sys/firmware/acpi/platform_profile 2>/dev/null)
  if _en_ac && _hay_dgpu; then nuevo="dgpu"; else nuevo="igpu"; fi
  if [ "$nuevo" != "$estado" ]; then
    if [ "$nuevo" = "dgpu" ]; then
      systemctl --user set-environment __NV_PRIME_RENDER_OFFLOAD=1 \
        __GLX_VENDOR_LIBRARY_NAME=nvidia __VK_LAYER_NV_optimus=NVIDIA_only DRI_PRIME=1
      dbus-update-activation-environment --systemd __NV_PRIME_RENDER_OFFLOAD=1 \
        __GLX_VENDOR_LIBRARY_NAME=nvidia __VK_LAYER_NV_optimus=NVIDIA_only DRI_PRIME=1
    else
      systemctl --user unset-environment "${VARS[@]}"
      dbus-update-activation-environment --systemd __NV_PRIME_RENDER_OFFLOAD=0 \
        __GLX_VENDOR_LIBRARY_NAME= __VK_LAYER_NV_optimus= DRI_PRIME=
    fi
    estado="$nuevo"
  fi
  sleep 3
done
