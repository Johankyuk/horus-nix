#!/usr/bin/env bash
# horus-power — energía + ventiladores + GPU (Hybrid, para laptop). Horus.
#
# MODELO (todo gira en torno al PERFIL, sin comandos por juego):
#   La base es Hybrid. En BATERÍA la dGPU se autosuspende (D3cold, ~0W) cuando nada
#   la usa; en AC NO llega a dormir: queda en idle P8 (~2W). El compositor renderiza
#   en la iGPU. Bajo carga el wataje de la dGPU varía según el perfil (toggle Noctalia):
#     • silencio (quiet)      -> perfil power-saver. En batería la dGPU duerme; los
#                                juegos corren en la iGPU.
#     • equilibrado (balanced)-> los juegos usan la dGPU a wataje medio.
#     • rendimiento (perf)    -> los juegos usan la dGPU a tope (~máx del chip).
#   El "gatillo" es el wrapper de juegos (horus-gpu / wrapper de Steam) que mira el
#   perfil y decide iGPU vs dGPU. El wataje lo aplica horus-power-hook automáticamente.
#
#   horus-power setup        deja la base lista: Hybrid + autosuspensión dGPU +
#                          compositor en iGPU + hook + prime-run. (Reinicia si venías de MUX.)
#   horus-power silencio     perfil power-saver (dGPU dormida).
#   horus-power equilibrado  perfil balanced.
#   horus-power rendimiento  perfil performance.
#   horus-power gpu-off      Integrated: dGPU apagada del TODO (reinicia). Para sesiones
#                          largas sin cargador donde ni quieres que exista la dGPU.
#   horus-power gpu-on       vuelve a Hybrid (reinicia).
#   horus-power noheat [off]  ventiladores 100% (solo rendimiento + AC).
#   horus-power --actual      estado.
set -uo pipefail
P='\033[0;35m'; G='\033[0;32m'; Y='\033[1;33m'; R='\033[0;31m'; N='\033[0m'
log(){ echo -e "${P}[power]${N} $1"; }; ok(){ echo -e "${G}[+]${N} $1"; }
warn(){ echo -e "${Y}[i]${N} $1"; }; err(){ echo -e "${R}[x]${N} $1"; }

CURVA_QUIET="30c:0%,55c:0%,63c:10%,70c:28%,78c:52%,85c:78%,91c:100%,97c:100%"
CURVA_BAL="30c:0%,50c:12%,60c:28%,70c:45%,78c:62%,85c:82%,91c:100%,96c:100%"
CURVA_PERF="35c:25%,48c:42%,58c:60%,67c:78%,74c:92%,81c:100%,88c:100%,95c:100%"
CURVA_MAX="20c:100%,40c:100%,55c:100%,65c:100%,75c:100%,85c:100%,90c:100%,95c:100%"

_curva(){
    command -v asusctl &>/dev/null || { warn "asusctl no disponible."; return 1; }
    asusctl fan-curve --mod-profile "$1" --fan cpu --data "$2" &>/dev/null
    asusctl fan-curve --mod-profile "$1" --fan gpu --data "$2" &>/dev/null
    asusctl fan-curve --mod-profile "$1" --enable-fan-curves true &>/dev/null
}
_perfil(){
    powerprofilesctl set "$1" 2>/dev/null && ok "Perfil de energía -> $1" \
        || warn "No se pudo fijar $1 (¿power-profiles-daemon?)."
}
_en_ac(){ for p in /sys/class/power_supply/*/online; do
        [ -r "$p" ] && [ "$(cat "$p" 2>/dev/null)" = "1" ] && return 0; done; return 1; }

# ── dGPU que se autosuspende (D3cold) cuando nada la usa ──
_gpu_autosuspend(){
    sudo install -Dm644 /dev/stdin /etc/modprobe.d/horus-nvidia-pm.conf <<'EOF'
# Horus — autosuspensión fina de la dGPU (PRIME dynamic power management).
options nvidia NVreg_DynamicPowerManagement=0x02
EOF
    sudo install -Dm644 /dev/stdin /etc/udev/rules.d/80-horus-nvidia-pm.rules <<'EOF'
# Horus — runtime PM de la dGPU NVIDIA (VGA + audio/usb del paquete).
ACTION=="bind",   SUBSYSTEM=="pci", DRIVERS=="nvidia", ATTR{class}=="0x030000", TEST=="power/control", ATTR{power/control}="auto"
ACTION=="bind",   SUBSYSTEM=="pci", DRIVERS=="nvidia", ATTR{class}=="0x030200", TEST=="power/control", ATTR{power/control}="auto"
ACTION=="unbind", SUBSYSTEM=="pci", DRIVERS=="nvidia", ATTR{class}=="0x030000", TEST=="power/control", ATTR{power/control}="on"
ACTION=="unbind", SUBSYSTEM=="pci", DRIVERS=="nvidia", ATTR{class}=="0x030200", TEST=="power/control", ATTR{power/control}="on"
EOF
    ok "dGPU configurada para dormir (D3cold) cuando esté ociosa."
    command -v mkinitcpio &>/dev/null && { sudo mkinitcpio -P &>/dev/null \
        && ok "initramfs regenerado." || warn "Regenera a mano: sudo mkinitcpio -P"; }
}

# ── Compositor en la iGPU (para que el escritorio NO despierte la dGPU) ──
_render_igpu(){
    local misc="$HOME/.config/niri/cfg/misc.kdl"
    [ -f "$misc" ] || { warn "No hay $misc; me salto el render-device."; return 0; }
    grep -q 'render-drm-device' "$misc" && { ok "Compositor ya fijado a iGPU."; return 0; }
    local node="" d rn drv
    for d in /dev/dri/by-path/*-render; do
        [ -e "$d" ] || continue
        rn=$(basename "$(readlink -f "$d")")
        drv=$(basename "$(readlink -f "/sys/class/drm/$rn/device/driver")" 2>/dev/null || true)
        case "$drv" in amdgpu|i915|xe) node="$d"; break ;; esac
    done
    [ -z "$node" ] && { warn "No detecté la iGPU; me salto el render-device."; return 0; }
    cp "$misc" "$misc.kyubak" 2>/dev/null
    if grep -q 'debug {' "$misc"; then
        sed -i "0,/debug {/ s|debug {|debug {\n        render-drm-device \"$node\"|" "$misc"
    else
        printf '\n    debug {\n        render-drm-device "%s"\n    }\n' "$node" >> "$misc"
    fi
    ok "Compositor -> iGPU ($node). Aplica al reiniciar la sesión."
}

_ensure_gpu(){ # $1 = Hybrid | Integrated
    command -v supergfxctl &>/dev/null || { err "Falta supergfxctl."; return 1; }
    systemctl is-active supergfxd &>/dev/null || {
        warn "Habilitando supergfxd (una vez, pide sudo)..."
        sudo systemctl enable --now supergfxd || return 1; }
    local target="$1" cur; cur=$(supergfxctl -g 2>/dev/null)
    [ "$cur" = "$target" ] && { ok "GPU ya en $target."; return 0; }
    warn "Cambiar GPU ($cur -> $target) cierra sesión / reinicia."
    if [ -t 0 ]; then read -rp "  ¿Continuar? [s/N] " r; [[ "$r" =~ ^[sS]$ ]] || { log "Cancelado."; return 1; }; fi
    supergfxctl -m "$target" && log "GPU -> $target. Reinicia para aplicar." || err "Falló el cambio."
}

case "${1:-}" in
    setup)
        _curva quiet "$CURVA_QUIET"; _curva balanced "$CURVA_BAL"; _curva performance "$CURVA_PERF"
        ok "Curvas de los 3 perfiles definidas en asusd."
        if systemctl list-unit-files horus-power-hook.service &>/dev/null; then
            sudo systemctl enable --now horus-power-hook && ok "Hook de power-limit habilitado."
        else warn "horus-power-hook.service no instalado (despliégalo)."; fi
        command -v prime-run &>/dev/null || { warn "Falta prime-run; instalando nvidia-prime..."; sudo pacman -S --needed --noconfirm nvidia-prime; }
        lspci 2>/dev/null | grep -qi nvidia && _gpu_autosuspend
        _render_igpu
        _ensure_gpu Hybrid
        warn "Silencio=dGPU dormida · Equilibrado/Rendimiento=juegos en dGPU (automático por perfil)."
        echo -e "${G}✓ Configuración de energía/GPU lista.${N}"
        ;;
    silencio|eco|ahorro) _perfil power-saver ;;
    equilibrado|equi|eq) _perfil balanced ;;
    rendimiento|rend|re) _perfil performance ;;
    gpu-off)             _ensure_gpu Integrated ;;
    gpu-on)              _ensure_gpu Hybrid ;;
    noheat)
        if [ "${2:-on}" = "off" ]; then _curva performance "$CURVA_PERF" && ok "Curva de rendimiento restaurada."; exit 0; fi
        prof=$(cat /sys/firmware/acpi/platform_profile 2>/dev/null)
        [ "$prof" = performance ] || { err "noheat solo en rendimiento (estás en '${prof:-?}')."; exit 1; }
        _en_ac || { err "noheat solo con cargador conectado."; exit 1; }
        _curva performance "$CURVA_MAX" && ok "Ventiladores al 100%. Restaura: horus-power noheat off"
        ;;
    --actual|actual)
        echo "Modo GPU:   $(supergfxctl -g 2>/dev/null || echo '?')"
        echo "Perfil:     $(cat /sys/firmware/acpi/platform_profile 2>/dev/null || echo '?')"
        if nvidia-smi -q -d POWER &>/dev/null; then
            echo "dGPU:       DESPIERTA ($(nvidia-smi --query-gpu=power.draw,power.limit --format=csv,noheader 2>/dev/null))"
        else echo "dGPU:       dormida (D3cold)"; fi
        _en_ac && echo "AC:         conectado" || echo "AC:         batería"
        ;;
    *) echo "uso: horus-power [setup|silencio|equilibrado|rendimiento|gpu-off|gpu-on|noheat [off]|--actual]" ;;
esac
